---
import { services } from "@lib/services.ts"
---

<section id="servicios" class="relative z-10 flex flex-col bg-linear-to-b from-gray-50 to-gray-100 px-4 py-16 lg:py-20 rounded-t-3xl lg:rounded-t-[3rem] shadow-[-10px_0_30px_-5px_rgba(0,0,0,0.1)]">
  <div class="max-w-7xl mx-auto w-full">
    <h2 class="mb-4 font-bold text-4xl text-center text-gray-900 reveal">Nuestros Servicios</h2>
    <p class="mb-12 text-center text-gray-600 max-w-2xl mx-auto reveal reveal-delay-100">Ofrecemos una amplia variedad de tratamientos dentales especializados con tecnología de última generación para tu bienestar bucal</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        services.map((service) => (
          <div class="relative rounded-xl overflow-hidden shadow-lg h-64 lg:h-72 reveal cursor-pointer">
            <img
              loading="lazy"
              alt={service.name}
              src={service.photo}
              class="absolute w-full h-full object-cover transition-none"
            />
            <div class="absolute bottom-0 left-0 right-0 h-32 bg-linear-to-t from-black/80 via-black/40 to-transparent"/>
            
            <div class="absolute inset-0 flex flex-col justify-end p-6 text-white">
              <h3 class="font-bold text-xl">
                {service.name}
              </h3>
            </div>
          </div>
        ))
      }
    </div>

    <div class="flex justify-center mt-12">
      <a href="#solicitar-cita" class="bg-blue-600 hover:bg-blue-700 text-white font-bold px-8 py-3 rounded-lg transition-all duration-300 shadow-lg hover:shadow-xl hover:-translate-y-1">
        Agendar Consulta
      </a>
    </div>
  </div>
</section>
